# === PRODUCTION .env — copy to /var/www/pattayavicecity/.env.local ===

# Database (generated by vps-setup.sh)
DATABASE_URL="postgresql://pattaya:YOUR_PASSWORD@localhost:5432/pattayavicecity"

# Session — CHANGE THIS (run: openssl rand -base64 32)
SESSION_SECRET="CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32"

# App URL — your actual domain
NEXT_PUBLIC_APP_URL="https://pattayavicecity.com"

# NextAuth — CHANGE THIS (run: openssl rand -base64 32)
AUTH_SECRET="CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32"

# Google OAuth — get from https://console.cloud.google.com
# Redirect URI: https://pattayavicecity.com/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
